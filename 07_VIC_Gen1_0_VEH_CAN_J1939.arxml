            <COMPU-METHOD UUID="6d66e634-93a3-4b3e-bd59-3478814a83a2">
              <SHORT-NAME>ErrLvl_CompuMethod</SHORT-NAME>
              <CATEGORY>TEXTTABLE</CATEGORY>
              <UNIT-REF DEST="UNIT">/Vehicle_CAN_Bus_J1939/DataTypes/ErrLvl_Unit</UNIT-REF>
