            </SW-BASE-TYPE>
            <DATA-CONSTR UUID="0fb72eab-1bed-4616-9952-3da6616192b7">
              <SHORT-NAME>Crash_Cks_Coding_PHYSICAL_VALID</SHORT-NAME>
              <DATA-CONSTR-RULES>
                <DATA-CONSTR-RULE>
                  <CONSTR-LEVEL>0</CONSTR-LEVEL>
                  <PHYS-CONSTRS>
                    <LOWER-LIMIT>0</LOWER-LIMIT>
                    <UPPER-LIMIT>15</UPPER-LIMIT>
                  </PHYS-CONSTRS>
                </DATA-CONSTR-RULE>
              </DATA-CONSTR-RULES>
            </DATA-CONSTR>
            <COMPU-METHOD UUID="565d6bac-dd80-4d2f-a8c2-7c98bc96b858">
              <SHORT-NAME>Crash_Cks_CompuMethod</SHORT-NAME>
              <CATEGORY>TEXTTABLE</CATEGORY>
              <UNIT-REF DEST="UNIT">/Vehicle_CAN_Bus_J1939/DataTypes/Crash_Cks_Unit</UNIT-REF>
              <COMPU-INTERNAL-TO-PHYS>
                <COMPU-SCALES>
                  <COMPU-SCALE>
                    <LOWER-LIMIT INTERVAL-TYPE="CLOSED">1</LOWER-LIMIT>
                    <UPPER-LIMIT INTERVAL-TYPE="CLOSED">1</UPPER-LIMIT>
                    <COMPU-CONST>
                      <VT>Checksum = ((Checksum &gt;&gt; 4) + Checksum) &amp; 0Fh</VT>
                    </COMPU-CONST>
                  </COMPU-SCALE>
                  <COMPU-SCALE>
                    <LOWER-LIMIT INTERVAL-TYPE="CLOSED">0</LOWER-LIMIT>
                    <UPPER-LIMIT INTERVAL-TYPE="CLOSED">0</UPPER-LIMIT>
                    <COMPU-CONST>
                      <VT>Checksum = (Byte1 + Byte2 + Byte3 + Byte4 + Byte5 + Byte6 + Byte7 + (message counter &amp; 0Fh) + message ID low byte + message ID mid low byte + message ID mid high byte + message ID high byte)</VT>
                    </COMPU-CONST>
                  </COMPU-SCALE>
                </COMPU-SCALES>
              </COMPU-INTERNAL-TO-PHYS>
            </COMPU-METHOD>
